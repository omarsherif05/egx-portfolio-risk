# Backend (Render) — api.py
# Comma-separated list of origins allowed to call the API via CORS.
# Defaults to http://localhost:3000 if unset. Add the deployed Vercel
# domain here once it exists, e.g.:
# ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Frontend (Vercel) — egx-risk-frontend/src/app/page.tsx
# Full URL of the analyze-portfolio endpoint on the deployed backend.
# Must be prefixed with NEXT_PUBLIC_ since it is read in the browser.
# Defaults to http://127.0.0.1:8000/api/v1/analyze-portfolio if unset.
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api/v1/analyze-portfolio
